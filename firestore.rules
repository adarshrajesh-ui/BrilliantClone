rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /streaks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /chapterProgress/{progressId} {
      allow read, write: if request.auth != null
        && progressId == request.auth.uid + '_expected_value_intro';
    }

    match /milestones/{milestoneId} {
      allow read, write: if request.auth != null
        && milestoneId == request.auth.uid + '_expected_value_intro';
    }

    match /problemAttempts/{attemptId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /problemSessions/{sessionId} {
      allow read, write: if request.auth != null
        && sessionId.matches('^' + request.auth.uid + '_.*');
    }

    match /lessonProgress/{lessonProgressId} {
      allow read, write: if request.auth != null
        && lessonProgressId.matches('^' + request.auth.uid + '_.*');
    }

    match /problemProgress/{problemProgressId} {
      allow read, write: if request.auth != null
        && problemProgressId.matches('^' + request.auth.uid + '_.*');
    }

    // Generated practice instances include private answer keys and are accessed
    // only through Vercel API routes. Admin SDK writes bypass rules.
    match /generatedPractice/{problemId} {
      allow read, write: if false;
    }

    match /generatedProblemAttempts/{attemptId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /practiceUsage/{usageId} {
      allow read, write: if false;
    }
  }
}
