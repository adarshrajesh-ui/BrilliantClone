rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /chapterProgress/{progressId} {
      allow read, write: if request.auth != null
        && progressId == request.auth.uid + '_expected_value_intro';
    }

    match /milestones/{milestoneId} {
      allow read, write: if request.auth != null
        && milestoneId == request.auth.uid + '_expected_value_intro';
    }

    match /problemAttempts/{attemptId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /problemSessions/{sessionId} {
      allow read, write: if request.auth != null
        && sessionId.matches('^' + request.auth.uid + '_.*');
    }
  }
}
